# Docker Compose Environment Configuration
# Copy to .env and customize as needed
# Per D-18: Configuration via .env file at Docker Compose root
# Per D-20: .env.example checked in, actual .env gitignored

# Ports
FRONTEND_PORT=80
BACKEND_PORT=8000
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2323

# Service names (Docker Compose internal - do not change)
BACKEND_HOST=backend
FRONTEND_HOST=frontend
NGINX_HOST=nginx
COWRIE_HOST=cowrie

# Volume paths
COWRIE_LOG_PATH=/var/log/cowrie

# Production Configuration (VPS deployment)
# Copy to .env on server and fill in values

# Domain name (required for SSL certificate)
DOMAIN=your-domain.com

# Admin credentials (used by deploy/setup-htpasswd.sh)
ADMIN_USER=admin
# Note: ADMIN_PASSWORD is entered interactively when running setup-htpasswd.sh
# Do NOT store plaintext passwords in .env files

# Certificate paths (Let's Encrypt default locations)
CERT_PATH=/etc/letsencrypt/live

# WebSocket Authentication (per SEC-02)
# Generate a secure token with: openssl rand -hex 32
# Optional: Leave empty for development (no auth)
WEBSOCKET_AUTH_TOKEN=